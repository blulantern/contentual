# Anthropic API Key (Optional - can be configured in-app via Settings)
NEXT_PUBLIC_ANTHROPIC_API_KEY=your_api_key_here

# AI fixture mode: off | record | replay (see .env.example for details)
NEXT_PUBLIC_AI_FIXTURE_MODE=off

# Supabase (required) — see .env.example for setup steps.
#
# Local Supabase via `npm run db:start` exposes the API at port 54321.
# After `db:start`, the CLI prints an "anon key" — paste it below.
# The URL is stable so you can leave it as-is when running locally.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
