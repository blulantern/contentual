# Anthropic API Key
# Optional — you can also configure this in-app via the Settings page,
# which persists to localStorage (key: "contentual_ai_config").
#
# Get a key at: https://console.anthropic.com/settings/keys
#
# WARNING: This is exposed to the browser (NEXT_PUBLIC_ prefix) because
# the Anthropic SDK runs client-side with dangerouslyAllowBrowser. Use
# only for local/personal development. For production, move calls to a
# Next.js API route and drop the NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_ANTHROPIC_API_KEY=your_api_key_here
