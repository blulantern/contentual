# Anthropic API Key
# Optional — you can also configure this in-app via the Settings page,
# which persists to localStorage (key: "contentual_ai_config").
#
# Get a key at: https://console.anthropic.com/settings/keys
#
# WARNING: This is exposed to the browser (NEXT_PUBLIC_ prefix) because
# the Anthropic SDK runs client-side with dangerouslyAllowBrowser. Use
# only for local/personal development. For production, move calls to a
# Next.js API route and drop the NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_ANTHROPIC_API_KEY=your_api_key_here

# AI fixture mode (testing aid — avoids burning tokens)
#   off     — normal behavior (default)
#   record  — hit the real API, persist each response to BOTH localStorage
#             ("contentual_ai_fixtures") AND fixtures/ai/<hash>.json on disk
#             (via the dev-only /api/fixtures route). Hash =
#             sha256(cacheKey + systemPrompt + prompt + model), 16 hex chars.
#   replay  — read from localStorage first; on miss, rehydrate from disk;
#             throw if neither has the fixture
#
# Workflow: set to "record", click through the app once, commit
# fixtures/ai/*.json so the team shares them. Then set to "replay" and
# develop offline. Tests can read the same files via
# src/lib/ai/fixtures-fs.ts. testConnection() always hits the real API.
NEXT_PUBLIC_AI_FIXTURE_MODE=off

# Supabase — REQUIRED for persistence. Stores profile, weekly plans,
# trend dictionary, niche meta, and content-ideas cache.
#
# LOCAL DEV (recommended):
#   1. Install the Supabase CLI: https://supabase.com/docs/guides/local-development/cli/getting-started
#   2. Run `npm run db:start` (uses Docker, applies supabase/migrations/)
#   3. Copy the anon key the CLI prints into NEXT_PUBLIC_SUPABASE_ANON_KEY
#   4. URL stays at the local default (port 54321)
#
# HOSTED (Supabase Cloud):
#   1. Create a project at https://supabase.com/dashboard
#   2. Settings → API → copy Project URL + "anon public" key below
#   3. SQL editor → run supabase/migrations/20240101000000_init.sql
#
# WARNING: The schema grants permissive RLS to the `anon` role (single-user
# app, no auth). Anyone with the deployed URL can read/write your data. Do
# NOT deploy publicly without first adding auth + per-user policies.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
